<%- include('../partials/head', { title }) %>
<body class="dashboard-page">
<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

    .dashboard-page {
        padding-top: 0;
        font-family: 'Inter', 'Segoe UI', sans-serif;
        color: rgba(236, 242, 255, 0.96);
        background:
            linear-gradient(180deg, rgba(4, 8, 24, 0.74) 0%, rgba(4, 8, 24, 0.84) 45%, rgba(4, 8, 24, 0.92) 100%),
            url('/photos/hero%20bg.jpg') center/cover no-repeat fixed !important;
    }

    .dashboard-page .dashboard {
        padding-top: 0;
    }

    .dashboard-page .main-content {
        background: transparent !important;
        padding: clamp(1rem, 2vw, 2rem);
    }

    .dashboard-page .card,
    .dashboard-page .stat-card,
    .dashboard-page .page-toolbar,
    .dashboard-page .countdown-box,
    .dashboard-page .progress-info-card,
    .dashboard-page .summary-grid .card,
    .dashboard-page .summary-card {
        background: linear-gradient(180deg, rgba(11, 18, 39, 0.74), rgba(11, 18, 39, 0.56)) !important;
        backdrop-filter: blur(18px) saturate(140%);
        -webkit-backdrop-filter: blur(18px) saturate(140%);
        border: 1px solid rgba(148, 163, 184, 0.16) !important;
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.22);
        color: rgba(246, 249, 255, 0.98) !important;
        border-radius: 20px;
    }

    .dashboard-page .page-toolbar {
        display: grid;
        grid-template-columns: minmax(0, 1.5fr) auto;
        gap: 1rem;
        align-items: center;
        padding: 1.25rem 1.4rem;
        margin-bottom: 1.25rem;
        position: relative;
        overflow: hidden;
    }

    .dashboard-page .page-toolbar::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(0, 240, 255, 0.08), transparent 55%);
        pointer-events: none;
    }

    .dashboard-page .page-toolbar h1,
    .dashboard-page .card h1,
    .dashboard-page .card h2,
    .dashboard-page .card h3,
    .dashboard-page .stat-info h3,
    .dashboard-page .stat-info p,
    .dashboard-page .card-header h3,
    .dashboard-page .countdown-label,
    .dashboard-page .countdown-timer,
    .dashboard-page .countdown-subtext,
    .dashboard-page .progress-ring-percent,
    .dashboard-page .progress-ring-label,
    .dashboard-page .summary-label,
    .dashboard-page .summary-value {
        color: rgba(248, 250, 252, 0.98) !important;
    }

    .dashboard-page .inline-balance,
    .dashboard-page .copy-field,
    .dashboard-page .profile-avatar {
        background: rgba(255, 255, 255, 0.06) !important;
        color: rgba(248, 250, 252, 0.98) !important;
        border: 1px solid rgba(148, 163, 184, 0.16) !important;
    }

    .dashboard-page .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .dashboard-page .stat-card {
        padding: 1.15rem 1.1rem;
        border-radius: 18px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
    }

    .dashboard-page .stat-card:hover,
    .dashboard-page .card:hover,
    .dashboard-page .page-toolbar:hover {
        transform: translateY(-2px);
        border-color: rgba(0, 240, 255, 0.24) !important;
        box-shadow: 0 20px 44px rgba(0, 0, 0, 0.28);
    }

    .dashboard-page .stat-info h3 {
        font-size: 0.82rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        opacity: 0.72;
        margin-bottom: 0.45rem;
    }

    .dashboard-page .stat-info p {
        font-size: clamp(1.25rem, 3vw, 2rem);
        font-weight: 700;
        line-height: 1.08;
    }

    .dashboard-page .stat-icon {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        background: linear-gradient(135deg, rgba(0, 240, 255, 0.16), rgba(16, 43, 153, 0.18)) !important;
        border: 1px solid rgba(148, 163, 184, 0.16) !important;
        display: grid;
        place-items: center;
        color: #7dd3fc !important;
        flex-shrink: 0;
    }

    .dashboard-page .investment-progress-card {
        margin-bottom: 1.25rem;
    }

    .dashboard-page .investment-progress-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    .dashboard-page .investment-progress-item {
        padding: 1.1rem;
        border-radius: 18px;
        background: linear-gradient(180deg, rgba(11, 18, 39, 0.82), rgba(11, 18, 39, 0.62));
        border: 1px solid rgba(148, 163, 184, 0.16);
        display: grid;
        gap: 0.95rem;
        min-width: 0;
    }

    .dashboard-page .investment-progress-shell {
        display: grid;
        grid-template-columns: minmax(240px, 340px) minmax(0, 1fr);
        gap: 1rem;
        align-items: stretch;
    }

    .dashboard-page .investment-progress-visual,
    .dashboard-page .investment-progress-meta,
    .dashboard-page .countdown-box,
    .dashboard-page .progress-info-card {
        min-width: 0;
    }

    .dashboard-page .investment-progress-visual {
        display: grid;
        gap: 0.95rem;
        align-content: start;
    }

    .dashboard-page .progress-ring {
        --ring-value: 100;
        width: min(100%, 280px);
        aspect-ratio: 1;
        border-radius: 50%;
        background:
            radial-gradient(circle at center, rgba(4, 8, 24, 0.94) 0 58%, transparent 59%),
            conic-gradient(from 180deg, #00f0ff 0%, #7c3aed 45%, #22c55e calc(var(--ring-value) * 1%), rgba(255, 255, 255, 0.08) 0);
        display: grid;
        place-items: center;
        position: relative;
        box-shadow:
            inset 0 0 0 1px rgba(255, 255, 255, 0.06),
            0 20px 50px rgba(0, 0, 0, 0.25);
        margin-inline: auto;
    }

    .dashboard-page .progress-ring::before {
        content: '';
        position: absolute;
        inset: 14px;
        border-radius: 50%;
        background: linear-gradient(180deg, rgba(9, 14, 29, 0.98), rgba(13, 19, 41, 0.88));
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .dashboard-page .progress-ring::after {
        content: '';
        position: absolute;
        inset: 9px;
        border-radius: 50%;
        border: 1px solid rgba(0, 240, 255, 0.12);
        filter: drop-shadow(0 0 12px rgba(0, 240, 255, 0.12));
    }

    .dashboard-page .progress-ring-content {
        position: relative;
        z-index: 1;
        text-align: center;
        display: grid;
        gap: 0.3rem;
    }

    .dashboard-page .progress-ring-percent {
        font-size: clamp(2rem, 7vw, 3rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1;
    }

    .dashboard-page .progress-ring-label {
        font-size: 0.82rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: rgba(191, 219, 254, 0.76) !important;
    }

    .dashboard-page .progress-bar-track {
        width: 100%;
        height: 10px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.06);
        overflow: hidden;
        border: 1px solid rgba(148, 163, 184, 0.14);
    }

    .dashboard-page .progress-bar-fill {
        height: 100%;
        width: var(--progress-value, 100%);
        border-radius: inherit;
        background: linear-gradient(90deg, #00f0ff, #7c3aed 50%, #22c55e);
        box-shadow: 0 0 22px rgba(0, 240, 255, 0.24);
        transition: width 0.5s ease;
    }

    .dashboard-page .countdown-box {
        background: linear-gradient(135deg, rgba(11, 18, 39, 0.88), rgba(8, 13, 30, 0.76)) !important;
        border-radius: 18px;
        padding: 1rem 1.1rem;
        display: grid;
        gap: 0.4rem;
    }

    .dashboard-page .countdown-label {
        display: block;
        font-size: 0.8rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(148, 163, 184, 0.9) !important;
    }

    .dashboard-page .countdown-timer {
        font-size: clamp(1.85rem, 5vw, 2.6rem);
        font-weight: 800;
        letter-spacing: 0.08em;
        font-variant-numeric: tabular-nums;
        line-height: 1;
    }

    .dashboard-page .countdown-subtext {
        font-size: 0.86rem;
        color: rgba(191, 219, 254, 0.75) !important;
    }

    .dashboard-page .progress-info-card {
        padding: 1rem 1.1rem;
        border-radius: 18px;
        display: grid;
        gap: 0.75rem;
        font-size: 0.95rem;
        line-height: 1.5;
    }

    .dashboard-page .progress-info-card strong {
        color: #ffffff;
    }

    .dashboard-page .investment-details-grid {
        display: grid;
        gap: 1rem;
    }

    .dashboard-page .investment-details-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 0.2rem;
    }

    .dashboard-page .badge-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.45rem 0.7rem;
        border-radius: 999px;
        background: rgba(0, 240, 255, 0.08);
        border: 1px solid rgba(0, 240, 255, 0.16);
        color: #c8fbff;
        font-size: 0.8rem;
        letter-spacing: 0.04em;
        white-space: nowrap;
    }

    .dashboard-page .investment-details-list {
        display: grid;
        gap: 0.8rem;
    }

    .dashboard-page .investment-detail-row {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.9rem 0;
        border-bottom: 1px solid rgba(148, 163, 184, 0.12);
    }

    .dashboard-page .investment-detail-row:last-child {
        border-bottom: 0;
        padding-bottom: 0;
    }

    .dashboard-page .investment-detail-label {
        color: rgba(191, 219, 254, 0.8);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .dashboard-page .investment-detail-value {
        font-weight: 700;
        text-align: right;
        color: rgba(248, 250, 252, 0.98);
    }

    .dashboard-page .referral-card {
        margin-bottom: 1.25rem;
    }

    .dashboard-page table {
        background: transparent !important;
    }

    .dashboard-page table thead th {
        background: rgba(255, 255, 255, 0.06) !important;
        color: rgba(241, 245, 249, 0.95) !important;
        border-bottom: 1px solid rgba(148, 163, 184, 0.18) !important;
    }

    .dashboard-page table tbody td {
        color: rgba(248, 250, 252, 0.94) !important;
        border-bottom: 1px solid rgba(148, 163, 184, 0.12) !important;
    }

    .dashboard-page .card-header {
        gap: 0.75rem;
    }

    .dashboard-page .section-title {
        display: flex;
        align-items: center;
        gap: 0.65rem;
    }

    .dashboard-page .section-title i {
        color: #00f0ff;
    }

    @media (max-width: 1100px) {
        .dashboard-page .stats-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .dashboard-page .investment-progress-shell {
            grid-template-columns: 1fr;
        }

        .dashboard-page .progress-ring {
            width: min(100%, 300px);
        }
    }

    @media (max-width: 720px) {
        .dashboard-page .page-toolbar {
            grid-template-columns: 1fr;
            padding: 1rem;
        }

        .dashboard-page .stats-grid {
            grid-template-columns: 1fr;
        }

        .dashboard-page .stat-card {
            padding: 1rem;
        }

        .dashboard-page .investment-detail-row {
            flex-direction: column;
            align-items: flex-start;
        }

        .dashboard-page .investment-detail-value {
            text-align: left;
        }
    }
</style>
    <div class="dashboard collapsible-dashboard">
        <%- include('../partials/userSidebar') %>
        <div class="main-content">
            <%- include('../partials/alerts') %>
            <div class="page-toolbar">
                <div>
                    <div class="section-title" style="margin-bottom: 0.25rem;"><i class="fas fa-sparkles"></i><span>Investment dashboard</span></div>
                    <h1 style="font-size: clamp(1.5rem, 4vw, 2.3rem); letter-spacing: -0.04em;">Welcome back, <%= currentUser.fullName %></h1>
                </div>
                <div class="inline-balance"><i class="fas fa-wallet"></i> Balance: <strong>UGX <%= Number(currentUser.balance).toLocaleString() %></strong></div>
            </div>

            <div class="stats-grid">
                <div class="stat-card"><div class="stat-info"><h3>Total Invested</h3><p><%= totals.totalInvested %></p></div><div class="stat-icon"><i class="fas fa-chart-pie"></i></div></div>
                <div class="stat-card"><div class="stat-info"><h3>Total Profit</h3><p><%= totals.totalProfit %></p></div><div class="stat-icon"><i class="fas fa-chart-line"></i></div></div>
                <div class="stat-card"><div class="stat-info"><h3>Active Investments</h3><p><%= totals.activeInvestmentsCount %></p></div><div class="stat-icon"><i class="fas fa-clock"></i></div></div>
                <div class="stat-card"><div class="stat-info"><h3>Referral Earnings</h3><p><%= totals.referralEarnings %></p></div><div class="stat-icon"><i class="fas fa-users"></i></div></div>
            </div>

            <%
              const progressInvestments = data.activeInvestments || [];
            %>
            <div class="card investment-progress-card">
                <div class="card-header">
                    <h3>Investment Progress (60 Days)</h3>
                </div>

                <% if (progressInvestments.length) { %>
                <div class="investment-progress-grid">
                    <% progressInvestments.forEach((investment, index) => {
                        const cycleDurationDays = Number(investment.durationDays) || 60;
                        const investmentName = investment.plan?.name || `Plan ${index + 1}`;
                    %>
                    <article
                        class="investment-progress-item"
                        data-progress-widget
                        data-start-date="<%= new Date(investment.startDate).toISOString() %>"
                        data-duration-days="<%= cycleDurationDays %>"
                    >
                        <div class="investment-details-title" style="margin-bottom: 0;">
                            <strong>Investment Progress (<%= cycleDurationDays %> Days)</strong>
                            <span class="badge-pill"><i class="fas fa-layer-group"></i> <%= investmentName %></span>
                        </div>

                        <div class="investment-progress-shell">
                            <div class="investment-progress-visual">
                                <div class="progress-ring" data-progress-ring style="--ring-value: 100;">
                                    <div class="progress-ring-content">
                                        <div class="progress-ring-percent" data-progress-percent>100%</div>
                                        <div class="progress-ring-label" data-progress-days><%= cycleDurationDays %> days left</div>
                                    </div>
                                </div>

                                <div>
                                    <div class="investment-details-title" style="margin-bottom: 0.65rem;">
                                        <strong>Cycle completion</strong>
                                        <span class="badge-pill"><i class="fas fa-circle-notch"></i> <%= cycleDurationDays %> day plan</span>
                                    </div>
                                    <div class="progress-bar-track" aria-hidden="true">
                                        <div class="progress-bar-fill" data-progress-bar style="--progress-value: 100%;"></div>
                                    </div>
                                </div>

                                <div class="countdown-box">
                                    <span class="countdown-label">Next Daily Profit In</span>
                                    <span class="countdown-timer" data-progress-countdown>--:--:--</span>
                                    <span class="countdown-subtext" data-progress-next-profit>Calculating next payout...</span>
                                </div>
                            </div>

                            <div class="investment-details-grid">
                                <div class="progress-info-card investment-progress-meta">
                                    <div class="investment-details-title">
                                        <strong>Current Investment</strong>
                                        <span class="badge-pill"><i class="fas fa-coins"></i> Live</span>
                                    </div>
                                    <div class="investment-details-list">
                                        <div class="investment-detail-row">
                                            <span class="investment-detail-label">Amount</span>
                                            <span class="investment-detail-value">UGX <%= Number(investment.principal).toLocaleString() %></span>
                                        </div>
                                        <div class="investment-detail-row">
                                            <span class="investment-detail-label">Started</span>
                                            <span class="investment-detail-value"><%= new Date(investment.startDate).toLocaleString() %></span>
                                        </div>
                                        <div class="investment-detail-row">
                                            <span class="investment-detail-label">Ends</span>
                                            <span class="investment-detail-value" data-progress-end-date><%= new Date(investment.endDate).toLocaleString() %></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </article>
                    <% }) %>
                </div>
                <% } else { %>
                <p style="color: rgba(255,255,255,0.7);">You do not have an active investment yet. Once you invest, each subscribed plan will appear here with its own 60-day progress tracker.</p>
                <% } %>
            </div>

            <div class="card referral-card">
                <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
                    <div style="flex: 1; min-width: 200px;">
                        <div class="section-title" style="margin-bottom: 0.4rem;"><i class="fas fa-link"></i><h3 style="margin: 0;">Your Referral Link</h3></div>
                        <p style="color: rgba(255,255,255,0.7); font-size: 0.9rem;">Share this link with friends to earn bonuses</p>
                    </div>
                    <div style="display: flex; gap: 1rem; flex: 1; min-width: 250px; flex-direction: column;">
                        <input id="referralLink" type="text" value="<%= appUrl %>/register?ref=<%= currentUser.referralCode %>" readonly class="copy-field">
                        <button class="btn btn-primary" onclick="copyReferralLink()" style="width: 100%;">Copy Link</button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h3>Active Investments</h3>
                    <a href="/invest" class="btn btn-primary btn-sm">Invest More</a>
                </div>
                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr><th>Plan</th><th>Amount</th><th>Daily Profit</th><th>Start Date</th><th>End Date</th><th>Status</th><th>Progress</th></tr>
                        </thead>
                        <tbody>
                            <% data.activeInvestments.forEach((item) => { 
                              const totalDays = item.durationDays;
                              const daysPassed = Math.min(totalDays, Math.max(0, Math.ceil((Date.now() - new Date(item.startDate).getTime()) / (24 * 60 * 60 * 1000))));
                              const dailyProfit = item.principal * (item.dailyRate / 100);
                            %>
                            <tr>
                                <td><%= item.plan?.name || 'Plan' %></td>
                                <td>UGX <%= Number(item.principal).toLocaleString() %></td>
                                <td>UGX <%= Number(dailyProfit).toLocaleString() %><br>(<%= item.dailyRate %>%)</td>
                                <td><%= new Date(item.startDate).toLocaleDateString() %></td>
                                <td><%= new Date(item.endDate).toLocaleDateString() %></td>
                                <td><span class="status-badge status-active">Active</span></td>
                                <td><%= daysPassed %>/<%= totalDays %> Days</td>
                            </tr>
                            <% }) %>
                            <% if (!data.activeInvestments.length) { %><tr><td colspan="7">No active investments yet.</td></tr><% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card" style="margin-top: 2rem;">
                <div class="card-header"><h3>Recent Transactions</h3></div>
                <div class="table-responsive">
                    <table>
                        <thead><tr><th>Date</th><th>Type</th><th>Amount</th><th>Status</th><th>Reference</th></tr></thead>
                        <tbody>
                            <% data.activityFeed.forEach((item) => { %>
                            <tr>
                                <td><%= new Date(item.createdAt).toLocaleDateString() %></td>
                                <td><%= item.title %></td>
                                <td><%= item.type === 'withdrawal' ? '-' : '+' %>UGX <%= Number(item.amount).toLocaleString() %></td>
                                <td><span class="status-badge status-<%= item.status %>"><%= item.status %></span></td>
                                <td><%= item.type.slice(0,3).toUpperCase() %>-<%= new Date(item.createdAt).getTime().toString().slice(-6) %></td>
                            </tr>
                            <% }) %>
                            <% if (!data.activityFeed.length) { %><tr><td colspan="5">No transactions yet.</td></tr><% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <%- include('../partials/scripts') %>
    <script>
      function copyReferralLink() {
        const input = document.getElementById('referralLink');
        input.select();
        input.setSelectionRange(0, 99999);
        navigator.clipboard.writeText(input.value);
        alert('Referral link copied to clipboard!');
      }

            function formatCountdown(ms) {
                const totalSeconds = Math.max(0, Math.floor(ms / 1000));
                const hours = Math.floor(totalSeconds / 3600);
                const minutes = Math.floor((totalSeconds % 3600) / 60);
                const seconds = totalSeconds % 60;

                return [hours, minutes, seconds]
                    .map((value) => String(value).padStart(2, '0'))
                    .join(':');
            }

            function initInvestmentProgress() {
                const widgets = document.querySelectorAll('[data-progress-widget]');
                if (!widgets.length) return;

                const dayMs = 24 * 60 * 60 * 1000;

                widgets.forEach((widget) => {
                    const ring = widget.querySelector('[data-progress-ring]');
                    const ringPercentText = widget.querySelector('[data-progress-percent]');
                    const ringDaysText = widget.querySelector('[data-progress-days]');
                    const secondaryProgressBar = widget.querySelector('[data-progress-bar]');
                    const endDateEl = widget.querySelector('[data-progress-end-date]');
                    const countdownEl = widget.querySelector('[data-progress-countdown]');
                    const nextProfitAtEl = widget.querySelector('[data-progress-next-profit]');

                    if (!ring || !ringPercentText || !ringDaysText || !secondaryProgressBar || !endDateEl || !countdownEl || !nextProfitAtEl) {
                        return;
                    }

                    const startDate = new Date(widget.dataset.startDate);
                    const durationDays = Number(widget.dataset.durationDays) || 60;
                    const durationMs = durationDays * dayMs;
                    const endDate = new Date(startDate.getTime() + durationMs);

                    endDateEl.textContent = endDate.toLocaleString();

                    function updateWidget() {
                        const now = new Date();
                        const elapsedMs = Math.max(0, now.getTime() - startDate.getTime());
                        const remainingMs = Math.max(0, endDate.getTime() - now.getTime());

                        const remainingRatio = Math.max(0, Math.min(1, 1 - elapsedMs / durationMs));
                        const remainingPercent = Math.round(remainingRatio * 100);
                        const remainingDays = Math.ceil(remainingMs / dayMs);
                        const completedPercent = 100 - remainingPercent;

                        ring.style.setProperty('--ring-value', String(remainingPercent));
                        secondaryProgressBar.style.setProperty('--progress-value', `${completedPercent}%`);
                        ringPercentText.textContent = `${remainingPercent}%`;
                        ringDaysText.textContent = remainingMs > 0 ? `${remainingDays} day${remainingDays === 1 ? '' : 's'} left` : 'Completed';

                        if (remainingMs <= 0) {
                            countdownEl.textContent = '00:00:00';
                            nextProfitAtEl.textContent = 'Investment period is complete.';
                            return;
                        }

                        const elapsedDays = Math.floor(elapsedMs / dayMs);
                        let nextProfitDate = new Date(startDate.getTime() + ((elapsedDays + 1) * dayMs));

                        if (nextProfitDate.getTime() > endDate.getTime()) {
                            nextProfitDate = endDate;
                        }

                        const countdownMs = Math.max(0, nextProfitDate.getTime() - now.getTime());
                        countdownEl.textContent = formatCountdown(countdownMs);
                        nextProfitAtEl.textContent = `Next payout: ${nextProfitDate.toLocaleString()}`;
                    }

                    updateWidget();
                    setInterval(updateWidget, 1000);
                });
            }

            initInvestmentProgress();
    </script>
