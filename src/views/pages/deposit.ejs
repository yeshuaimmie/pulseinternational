<%- include('../partials/head', { title }) %>
<body style="padding-top: 0; background: linear-gradient(rgba(8,10,69,0.85), rgba(0,240,255,0.45)), url('/photos/hero%20bg.jpg') center/cover no-repeat fixed !important; color: white !important;">
<style>
    .main-content { background: transparent !important; }
    .card, .stat-card {
        background: rgba(255, 255, 255, 0.05) !important;
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: white !important;
    }
    .card h1, .card h3, .stat-info h3, .stat-info p, .card-header h3 { color: white !important; }
    .stat-icon { background: rgba(255,255,255,0.1) !important; color: white !important; border: 1px solid rgba(255,255,255,0.1) !important; }
    table thead th { background: rgba(255,255,255,0.1) !important; color: white !important; }
    table tbody td { color: rgba(255,255,255,0.9) !important; }
</style>
<div class="dashboard">
  <%- include('../partials/userSidebar') %>

  <div class="main-content">
    <h1 style="margin-bottom: 2rem;">Make a Deposit</h1>
    <%- include('../partials/alerts') %>

    <div class="two-col-layout">
      <div class="card">
        <div class="card-header">
          <h3>Payment Instructions</h3>
        </div>

        <div style="margin-bottom: 1.5rem;">
          <h4 style="color: #ffcc00; margin-bottom: 0.5rem;">MTN Mobile Money</h4>
          <p>Number: +256768264096</p>
          <p>Lillian Musubika</p>
          <p><strong>Steps:</strong></p>
          <ol style="margin-left: 1rem;">
            <li>Dial *165#</li>
            <li>Select Send Money</li>
            <li>Enter+256768264096 </li>
            <li>Enter amount</li>
            <li>Enter PIN</li>
          </ol>
        </div>

        <div style="margin-bottom: 1.5rem;">
          <h4 style="color: #ed1c24; margin-bottom: 0.5rem;">Airtel Money</h4>
          <p>Number: +256752915902 </p>
          <p>Name: Safson wontonga</p>
          <p><strong>Steps:</strong></p>
          <ol style="margin-left: 1rem;">
            <li>Dial *165#</li>
            <li>Select Send Money</li>
            <li>Enter +256752915902</li>
            <li>Enter amount</li>
            <li>Enter PIN</li>
          </ol>
        </div>


        <div style="background: #f5f5f5; color:#222; padding: 1rem; border-radius: 5px;">
          <h4 style="margin-bottom: 0.5rem;">Important Notes:</h4>
          <ul style="list-style: none; padding-left: 0; margin:0;">
            <li style="margin-bottom: 0.5rem;"><i class="fas fa-check-circle" style="color: var(--success-color);"></i> Minimum deposit: UGX 10,000</li>
            <li style="margin-bottom: 0.5rem;"><i class="fas fa-check-circle" style="color: var(--success-color);"></i> Deposits are processed within 24 hours</li>
            <li style="margin-bottom: 0.5rem;"><i class="fas fa-check-circle" style="color: var(--success-color);"></i> Screenshots must be clear and readable</li>
          </ul>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h3>Deposit Funds</h3>
        </div>

        <form id="depositForm" method="POST" action="/deposit" enctype="multipart/form-data">
          <div class="form-group">
            <label for="amount">Amount to Deposit (UGX)</label>
            <input type="number" id="amount" name="amount" min="10000" required placeholder="Enter amount">
            <small style="color: rgba(255,255,255,0.7);">Minimum deposit: UGX 10,000</small>
          </div>

          <div class="form-group">
            <label for="paymentMethod">Payment Method</label>
            <select id="paymentMethod" name="paymentMethod" required>
              <option value="">Select Payment Method</option>
              <option value="mtn">MTN Mobile Money</option>
              <option value="airtel">Airtel Money</option>
              <option value="bank">Bank Transfer</option>

            </select>
          </div>

          <div class="form-group">
            <label for="phone">Mobile Money Number</label>
            <input type="tel" id="phone" name="phone" required placeholder="Enter your mobile money number">
          </div>

          <div class="form-group">
            <label for="screenshot">Upload Payment Screenshot</label>
            <input type="file" id="screenshot" name="proof" accept="image/*" required>
            <small style="color: rgba(255,255,255,0.7);">Upload a screenshot of your payment confirmation</small>
          </div>

          <div class="deposit-steps" style="margin-bottom: 1.5rem; background: rgba(76, 175, 80, 0.08); padding: 1rem; border-radius: 8px;">
            <h4 style="margin-bottom: 0.75rem;">How to Deposit</h4>
            <ol style="margin-left: 1.2rem;">
              <li style="margin-bottom: 0.5rem;"><strong>Step 1:</strong> Follow the payment instructions on the left and send funds to the mobile money number listed.</li>
              <li><strong>Step 2:</strong> Come back here, upload your payment screenshot, and submit your deposit request.</li>
            </ol>
          </div>

          <button type="submit" class="btn btn-primary" style="width: 100%;">Submit Deposit</button>
        </form>
      </div>
    </div>

    <div class="card" style="margin-top: 2rem;">
      <div class="card-header">
        <h3>Deposit History</h3>
      </div>

      <div class="table-responsive">
        <table>
          <thead>
            <tr>
              <th>Date</th>
              <th>Amount</th>
              <th>Method</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% deposits.forEach((deposit) => { %>
              <tr>
                <td><%= new Date(deposit.createdAt).toISOString().slice(0, 10) %></td>
                <td>UGX <%= Number(deposit.amount).toLocaleString() %></td>
                <td><%= deposit.paymentMethod === 'mtn' ? 'MTN Mobile Money' : deposit.paymentMethod === 'airtel' ? 'Airtel Money' : 'Bank Transfer' %></td>
                <td><span class="status-badge status-<%= deposit.status === 'approved' ? 'completed' : deposit.status %>"><%= deposit.status === 'approved' ? 'Completed' : deposit.status.charAt(0).toUpperCase() + deposit.status.slice(1) %></span></td>
              </tr>
            <% }) %>
            <% if (!deposits.length) { %>
              <tr><td colspan="4">No deposits yet.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
