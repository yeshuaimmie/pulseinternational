<%- include('../partials/head', { title }) %>
<body style="padding-top: 0; background: linear-gradient(rgba(8,10,69,0.85), rgba(0,240,255,0.45)), url('/photos/hero%20bg.jpg') center/cover no-repeat fixed !important; color: white !important;">
<style>
    .main-content { background: transparent !important; }
    .card, .stat-card, .page-toolbar {
        background: rgba(255, 255, 255, 0.05) !important;
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: white !important;
    }
    .card h1, .card h2, .card h3, .card h4, .stat-info h3, .stat-info p, .card-header h3, .page-toolbar h1 {
        color: white !important;
    }
    .stat-icon {
        background: rgba(255,255,255,0.1) !important;
        color: white !important;
        border: 1px solid rgba(255,255,255,0.1) !important;
    }
    table thead th { background: rgba(255,255,255,0.1) !important; color: white !important; border-bottom: 1px solid rgba(255,255,255,0.2) !important; }
    table tbody td { color: rgba(255,255,255,0.9) !important; border-bottom: 1px solid rgba(255,255,255,0.05) !important; }
    #referralLinkField { background: rgba(255,255,255,0.05) !important; color: white !important; border: 1px solid rgba(255,255,255,0.1) !important; }
</style>
<div class="dashboard">
  <%- include('../partials/userSidebar') %>

  <div class="main-content">
    <h1 style="margin-bottom: 2rem;">Referral Program</h1>
    <%- include('../partials/alerts') %>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-info">
          <h3>Total Referrals</h3>
          <p><%= stats.totalReferrals %></p>
        </div>
        <div class="stat-icon">
          <i class="fas fa-users"></i>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-info">
          <h3>Active Referrals</h3>
          <p><%= stats.activeReferrals %></p>
        </div>
        <div class="stat-icon">
          <i class="fas fa-user-check"></i>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-info">
          <h3>Referral Earnings</h3>
          <p>UGX <%= Number(stats.referralEarnings).toLocaleString() %></p>
        </div>
        <div class="stat-icon">
          <i class="fas fa-money-bill-wave"></i>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-info">
          <h3>Commission Rate</h3>
          <p><%= stats.commissionRate %></p>
        </div>
        <div class="stat-icon">
          <i class="fas fa-percent"></i>
        </div>
      </div>
    </div>

    <div class="card" style="margin-bottom: 2rem;">
      <div class="card-header">
        <h3>Your Referral Link</h3>
      </div>
      <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
        <input id="referralLinkField" type="text" value="<%= referralLink %>" readonly style="flex: 1; padding: 0.8rem; border: 1px solid #ddd; border-radius: 5px;">
        <button class="btn btn-primary" onclick="copyReferralLink()" type="button">Copy Link</button>
        <button class="btn btn-secondary" onclick="shareReferral()" type="button">Share</button>
      </div>
    </div>

    <div class="card" style="margin-bottom: 2rem;">
      <div class="card-header">
        <h3>How Referral Works</h3>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem;">
        <div style="text-align: center;">
          <div style="width: 50px; height: 50px; background: var(--primary-color); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-size: 1.5rem;">1</div>
          <h4>Share Your Link</h4>
          <p>Share your unique referral link with friends</p>
        </div>
        <div style="text-align: center;">
          <div style="width: 50px; height: 50px; background: var(--primary-color); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-size: 1.5rem;">2</div>
          <h4>Friend Registers</h4>
          <p>They sign up using your referral link</p>
        </div>
        <div style="text-align: center;">
          <div style="width: 50px; height: 50px; background: var(--primary-color); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-size: 1.5rem;">3</div>
          <h4>They Invest</h4>
          <p>They make their first investment</p>
        </div>
        <div style="text-align: center;">
          <div style="width: 50px; height: 50px; background: var(--primary-color); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-size: 1.5rem;">4</div>
          <h4>You Earn</h4>
          <p>Earn commission on their investment</p>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <h3>Your Referrals</h3>
      </div>

      <div class="table-responsive">
        <table>
          <thead>
            <tr>
              <th>Name</th>
              <th>Joined Date</th>
              <th>Investment</th>
              <th>Your Commission</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% referralRows.forEach((row) => { %>
              <tr>
                <td><%= row.user.fullName %></td>
                <td><%= new Date(row.user.createdAt).toISOString().slice(0, 10) %></td>
                <td>UGX <%= Number(row.investedAmount || 0).toLocaleString() %></td>
                <td>UGX <%= Number(row.totalCommission || 0).toLocaleString() %></td>
                <td><span class="status-badge status-<%= row.status %>"><%= row.status === 'active' ? 'Active' : 'Pending' %></span></td>
              </tr>
            <% }) %>
            <% if (!referralRows.length) { %>
              <tr><td colspan="5">No referrals yet.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  function copyReferralLink() {
    const input = document.getElementById('referralLinkField');
    navigator.clipboard.writeText(input.value);
    alert('Referral link copied to clipboard!');
  }

  function shareReferral() {
    const url = document.getElementById('referralLinkField').value;
    if (navigator.share) {
      navigator.share({
        title: 'Join Pulse Investors Uganda',
        text: 'Start investing with me on Pulse Investors and earn daily profits!',
        url,
      });
    } else {
      navigator.clipboard.writeText(url);
      alert('Sharing is not supported on this browser. The link has been copied instead.');
    }
  }
</script>
<%- include('../partials/scripts') %>
