<%- include('../partials/head', { title }) %>
<body style="padding-top: 0; background: linear-gradient(rgba(8,10,69,0.85), rgba(0,240,255,0.45)), url('/photos/hero%20bg.jpg') center/cover no-repeat fixed !important; color: white !important;">
<style>
    .main-content { background: transparent !important; }
    .card {
        background: rgba(255, 255, 255, 0.05) !important;
        backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: white !important;
    }
    .card h1, .card h3 {
        color: white !important;
    }
    table thead th { background: rgba(255,255,255,0.1) !important; color: white !important; border-bottom: 1px solid rgba(255,255,255,0.2) !important; }
    table tbody td { color: rgba(255,255,255,0.9) !important; border-bottom: 1px solid rgba(255,255,255,0.05) !important; }
</style>
<div class="dashboard">
  <%- include('../partials/adminSidebar') %>
  <div class="main-content">
    <%- include('../partials/alerts') %>
    <h1 style="margin-bottom:1.5rem;">Investments</h1>
    <div class="card">
      <div class="card-header"><h3>All Investments</h3></div>
      <div class="table-responsive">
        <table>
          <thead><tr><th>User</th><th>Plan</th><th>Principal</th><th>Rate</th><th>Expected Return</th><th>Start</th><th>End</th><th>Status</th></tr></thead>
          <tbody>
            <% investments.forEach((item) => { %>
            <tr>
              <td><%= item.user?.fullName || '-' %><br><small><%= item.user?.email || '' %></small></td>
              <td><%= item.plan?.name || 'Plan' %></td>
              <td>UGX <%= Number(item.principal).toLocaleString() %></td>
              <td><%= item.dailyRate %>%</td>
              <td>UGX <%= Number(item.expectedReturn).toLocaleString() %></td>
              <td><%= new Date(item.startDate).toLocaleDateString() %></td>
              <td><%= new Date(item.endDate).toLocaleDateString() %></td>
              <td><span class="status-badge status-<%= item.status === 'completed' ? 'completed' : 'active' %>"><%= item.status %></span></td>
            </tr>
            <% }) %>
            <% if (!investments.length) { %><tr><td colspan="8">No investments found.</td></tr><% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/scripts') %>
